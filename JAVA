import java.util.*;
import java.sql.*;

public class CustomerData {

    Vector customerList = new Vector();

    public void loadCustomer() {

        Connection con = null;
        Statement st = null;
        ResultSet rs = null;

        try {

            Class.forName("com.mysql.jdbc.Driver");

            con = DriverManager.getConnection(
                    "jdbc:mysql://localhost:3306/company",
                    "root",
                    "root123");

            st = con.createStatement();

            rs = st.executeQuery("select * from customer");

            while (rs.next()) {

                Vector v = new Vector();

                v.add(rs.getInt("id"));
                v.add(rs.getString("name"));
                v.add(rs.getString("email"));
                v.add(rs.getDouble("balance"));

                customerList.add(v);

            }

            Enumeration e = customerList.elements();

            while (e.hasMoreElements()) {

                Vector x = (Vector)e.nextElement();

                int id = (Integer)x.get(0);
                String name = (String)x.get(1);
                String email = (String)x.get(2);
                double bal = (Double)x.get(3);

                if (bal > 10000) {

                    System.out.println(id + " " + name + " VIP Customer");

                } else {

                    System.out.println(id + " " + name + " Regular Customer");

                }

                if(email.indexOf("@") == -1){

                    System.out.println("Invalid Email");

                }

            }

        }
        catch(Exception ex){

            System.out.println(ex);

        }
    }

    public static void main(String args[]){

        CustomerData obj = new CustomerData();
        obj.loadCustomer();

    }

}
